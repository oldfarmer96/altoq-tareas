---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="¡Solicitud recibida!"
  description="Tu solicitud ha sido enviada correctamente."
>
  <Header />

  <main
    class="py-16 md:py-24 px-4 sm:px-6 lg:px-8 min-h-[60vh] flex items-center"
    style="background-color: var(--color-surface)"
  >
    <div class="max-w-2xl mx-auto text-center">
      <div class="text-6xl mb-6">✅</div>
      <h1 class="section-title mb-4">¡Solicitud enviada!</h1>
      <p class="text-lg mb-8" style="color: var(--color-muted)">
        Hemos recibido tu solicitud correctamente. En menos de 2 horas recibirás
        un correo con tu cotización personalizada.
      </p>
      <div class="card inline-block">
        <p class="font-semibold mb-2" style="color: var(--color-primary)">
          ¿Qué sigue?
        </p>
        <ul
          class="text-sm text-left space-y-2"
          style="color: var(--color-muted)"
        >
          <li>📧 Revisa tu correo (incluye carpeta de spam)</li>
          <li>💬 Puedes escribirnos por WhatsApp para consultas rápidas</li>
          <li>⏰ El tiempo de respuesta es de 1-2 horas</li>
        </ul>
      </div>
      <div class="mt-8">
        <a href="/" class="btn-primary">Volver al inicio</a>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
