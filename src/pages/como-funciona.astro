---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Cómo funciona"
  description="Conoce el proceso paso a paso de nuestro servicio."
>
  <Header />

  <main
    class="py-16 md:py-24 px-4 sm:px-6 lg:px-8"
    style="background-color: var(--color-surface)"
  >
    <div class="max-w-4xl mx-auto">
      <h1 class="section-title mb-8 text-center">¿Cómo funciona?</h1>

      <div class="space-y-12">
        <div class="flex gap-6 items-start">
          <div
            class="shrink-0 w-12 h-12 rounded-full flex items-center justify-center text-xl font-bold"
            style="background-color: var(--color-accent); color: var(--color-primary)"
          >
            1
          </div>
          <div>
            <h2
              class="text-xl font-bold mb-2"
              style="color: var(--color-primary)"
            >
              Envía tu solicitud
            </h2>
            <p style="color: var(--color-muted)">
              Completa el formulario con los detalles de tu tarea: tipo de
              trabajo, materia, descripción y archivos de referencia (Google
              Drive o OneDrive).
            </p>
          </div>
        </div>

        <div class="flex gap-6 items-start">
          <div
            class="shrink-0 w-12 h-12 rounded-full flex items-center justify-center text-xl font-bold"
            style="background-color: var(--color-accent); color: var(--color-primary)"
          >
            2
          </div>
          <div>
            <h2
              class="text-xl font-bold mb-2"
              style="color: var(--color-primary)"
            >
              Recibe tu cotización
            </h2>
            <p style="color: var(--color-muted)">
              En menos de 2 horas te enviamos un correo con el precio, plazo de
              entrega y condiciones. Sin compromiso.
            </p>
          </div>
        </div>

        <div class="flex gap-6 items-start">
          <div
            class="shrink-0 w-12 h-12 rounded-full flex items-center justify-center text-xl font-bold"
            style="background-color: var(--color-accent); color: var(--color-primary)"
          >
            3
          </div>
          <div>
            <h2
              class="text-xl font-bold mb-2"
              style="color: var(--color-primary)"
            >
              Confirma y paga
            </h2>
            <p style="color: var(--color-muted)">
              Si aceptas, haces la transferencia o pago por Yape/BCP/Interbank.
              Te enviamos comprobante de inmediato.
            </p>
          </div>
        </div>

        <div class="flex gap-6 items-start">
          <div
            class="shrink-0 w-12 h-12 rounded-full flex items-center justify-center text-xl font-bold"
            style="background-color: var(--color-accent); color: var(--color-primary)"
          >
            4
          </div>
          <div>
            <h2
              class="text-xl font-bold mb-2"
              style="color: var(--color-primary)"
            >
              Recibe tu trabajo
            </h2>
            <p style="color: var(--color-muted)">
              Te entregamos el trabajo completo en tu correo antes del plazo
              acordado, con reporte de originalidad incluido.
            </p>
          </div>
        </div>
      </div>

      <div class="mt-12 text-center">
        <a href="/cotizar" class="btn-primary">Comenzar →</a>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
