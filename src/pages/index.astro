---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "../components/HeroSection.astro";
import TypeHomework from "../components/TypeHomework.astro";
import HowItWorks from "../components/HowItWorks.astro";
import Warranty from "../components/Warranty.astro";
---

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "AltoQ.Tareas",
    "description": "Servicio de tareas universitarias en Perú. Calidad garantizada y entrega a tiempo.",
    "url": "https://altoq-tareas.vercel.app",
    "areaServed": "Perú",
    "serviceType": "Asesoría académica universitaria",
    "priceRange": "$$",
    "openingHours": "Mo-Su 08:00-22:00"
  }
</script>

<BaseLayout title="Haz tus tareas universitarias | AltoQ.Tareas">
  <main>
    <HeroSection />
    <!-- seccion de estadistica -->
    <TypeHomework />
    <HowItWorks />

    <Warranty />

    <section
      class="py-16 md:py-24 px-4 sm:px-6 lg:px-8"
      style="background-color: var(--color-primary)"
    >
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-6">
          ¿Listo para dejar las tareas atrás?
        </h2>
        <p class="text-lg text-white/80 mb-8">
          Envíanos tu solicitud ahora y recibe tu cotización en menos de 2
          horas.
        </p>
        <a href="/cotizar" class="btn-accent text-lg"> Cotizar mi tarea → </a>
      </div>
    </section>
  </main>
</BaseLayout>
