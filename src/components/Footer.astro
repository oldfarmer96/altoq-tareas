---
const currentYear = new Date().getFullYear();

const footerLinks = [
  { label: "Términos y condiciones", href: "/terminos-y-condiciones" },
  { label: "Política de privacidad", href: "/politica-de-privacidad" },
  { label: "Preguntas frecuentes", href: "/preguntas-frecuentes" },
];


---

<footer class="mt-auto" style="background-color: var(--color-primary)">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <div class="flex items-center gap-2 mb-4">
          <img src="/logo.webp" alt="AltoQ.Tareas" class="w-10 h-10 rounded-lg object-contain bg-white/10 p-1" />
          <span class="font-bold text-xl text-white">AltoQ.Tareas</span>
        </div>
        <p class="text-sm text-white/70 max-w-xs">
          Servicio profesional de tareas universitarias en Perú. Calidad
          garantizada, entrega a tiempo.
        </p>
      </div>

      <div>
        <h4 class="font-semibold text-white mb-4">Enlaces</h4>
        <ul class="space-y-2">
          {
            footerLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-white/70 hover:text-white transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h4 class="font-semibold text-white mb-4">Contacto</h4>
        <ul class="space-y-2">
          <li class="text-sm text-white/70">Email: laindots999@gmail.com</li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/10 mt-8 pt-8 text-center">
      <p class="text-sm text-white/50">
        © {currentYear} AltoQ.Tareas. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
