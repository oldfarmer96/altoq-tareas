---
import ResearchSvg from "../assets/icons/research.svg";
import LaptopSvg from "../assets/icons/laptop.svg";
import GraduationSvg from "../assets/icons/graduation.svg";
import PresentationSvg from "../assets/icons/presentation.svg";
import RulerSvg from "../assets/icons/ruler.svg";
import WritingSvg from "../assets/icons/writing.svg";
---

<section
  class="py-16 md:py-24 px-4 sm:px-6 lg:px-8"
  style="background-color: var(--color-surface)"
>
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="section-title mb-4">¿Qué tipo de tarea necesitas?</h2>
      <p class="section-subtitle max-w-2xl mx-auto">
        Cubrimos todas las materias y tipos de trabajo académico que tu
        universidad requiera.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="card">
        <div class="text-3xl mb-4">
          <WritingSvg width={48} height={48} />
        </div>
        <h3 class="text-lg font-bold mb-2" style="color: var(--color-primary)">
          Ensayos y trabajos escritos
        </h3>
        <p class="text-sm" style="color: var(--color-muted)">
          Ensayos, artículos y cualquier trabajo de escritura académica.
        </p>
      </div>
      <div class="card">
        <div class="text-3xl mb-4">
          <ResearchSvg width={48} height={48} />
        </div>
        <h3 class="text-lg font-bold mb-2" style="color: var(--color-primary)">
          Informes
        </h3>
        <p class="text-sm" style="color: var(--color-muted)">
          Informes de prácticas, informes de laboratorio e informes generales.
          Tu nos describes la tarea y la hacemos.
        </p>
      </div>
      <div class="card">
        <div class="text-3xl mb-4">
          <GraduationSvg width={48} height={48} />
        </div>
        <h3 class="text-lg font-bold mb-2" style="color: var(--color-primary)">
          Trabajos monográficos
        </h3>
        <p class="text-sm" style="color: var(--color-muted)">
          Trabajos monográficos completos con fuentes documentadas y
          bibliography actualizada.
        </p>
      </div>
      <div class="card">
        <div class="text-3xl mb-4">
          <RulerSvg width={48} height={48} />
        </div>
        <h3 class="text-lg font-bold mb-2" style="color: var(--color-primary)">
          Ejercicios y problemas
        </h3>
        <p class="text-sm" style="color: var(--color-muted)">
          Matemáticas, física, química, estadística y más. Con desarrollo paso a
          paso.
        </p>
      </div>
      <div class="card">
        <div class="text-3xl mb-4">
          <PresentationSvg width={48} height={48} />
        </div>
        <h3 class="text-lg font-bold mb-2" style="color: var(--color-primary)">
          Presentaciones
        </h3>
        <p class="text-sm" style="color: var(--color-muted)">
          PowerPoint, slides interactivos y presentaciones creativas para
          exposiciones.
        </p>
      </div>
      <div class="card">
        <div class="text-3xl mb-4">
          <LaptopSvg width={48} height={48} />
        </div>
        <h3 class="text-lg font-bold mb-2" style="color: var(--color-primary)">
          Código y programación
        </h3>
        <p class="text-sm" style="color: var(--color-muted)">
          JavaScript, TypeScript, Java, Python, Go, PHP y más.
        </p>
      </div>
      <div class="card">
        <div class="text-3xl mb-4">
          <GraduationSvg width={48} height={48} />
        </div>
        <h3 class="text-lg font-bold mb-2" style="color: var(--color-primary)">
          Tesis y proyectos de investigación
        </h3>
        <p class="text-sm" style="color: var(--color-muted)">
          Tesis de pregrado y posgrado, proyectos de investigación.
        </p>
      </div>
      <div class="card">
        <div class="text-3xl mb-4">
          <ResearchSvg width={48} height={48} />
        </div>
        <h3 class="text-lg font-bold mb-2" style="color: var(--color-primary)">
          Investigaciones
        </h3>
        <p class="text-sm" style="color: var(--color-muted)">
          Investigaciones documentadas con fuentes académicas confiables y
          actualizadas.
        </p>
      </div>
    </div>
  </div>
</section>
